{
  "name": "fleet-intelligence-mcp-server",
  "version": "1.0.0",
  "description": "Fleet Intelligence MCP Server for ACM Global Hub",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fleet-intelligence-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "tsup && node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "acm",
    "kubernetes",
    "fleet-health",
    "open-cluster-management"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.14.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2"
  }
}
